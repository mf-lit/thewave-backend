# Terraform state (contains sensitive data — never commit)
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl.bak

# Variable files with real values / secrets
terraform.tfvars
*.auto.tfvars

# Crash logs and plan output
crash.log
crash.*.log
*.tfplan

# Keys / credentials
*.pem
*.key
oci_api_key*

# Cached bastion session + its ephemeral private key (push-provision.sh)
.push-session/

# Restic backup secrets (B2 key, restic password) — never commit plaintext
restic/restic.env
