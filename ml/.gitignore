# Python bytecode / caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtual environments
.venv/
venv/

# Environment / secrets
.env

# Generated pipeline artifacts — regenerable on-demand (see README quickstart).
# Kept for on-demand forecasting: models/best/, data/hourly.csv, archive_*.parquet.
/forecast/                                    # forecast outputs (incl. latest.csv)
/logs/
/data/interim/                                # training feature intermediates
/data/processed/
/data/external/openmeteo/forecast_*.parquet   # 1h-TTL weather cache, re-fetched live
/models/state.json                            # runtime anchor; rebuilt via --update-state
